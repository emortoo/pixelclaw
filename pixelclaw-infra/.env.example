# PixelClaw Production Environment
# Copy to .env and fill in values

# Domain pointing to this server (DNS A record must exist)
DOMAIN=pixelclaw.yourdomain.com

# LLM provider API key for OpenClaw agent
# Leave empty for free models like moonshot/kimi-k2.5
MODEL_API_KEY=

# OpenClaw model (default: moonshot/kimi-k2.5)
# Other options: anthropic/claude-sonnet-4-20250514, openai/gpt-4o
OPENCLAW_MODEL=moonshot/kimi-k2.5
