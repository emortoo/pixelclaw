{
  "name": "pixelclaw",
  "displayName": "PixelClaw",
  "description": "Pixel art office where your OpenClaw agents come to life as animated characters",
  "version": "0.1.0",
  "publisher": "emortoo",
  "repository": {
    "type": "git",
    "url": "https://github.com/emortoo/pixelclaw.git"
  },
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pixelclaw.showPanel",
        "title": "PixelClaw: Show Panel"
      },
      {
        "command": "pixelclaw.exportDefaultLayout",
        "title": "PixelClaw: Export Layout as Default"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "pixelclaw-panel",
          "title": "PixelClaw",
          "icon": "$(window)"
        }
      ]
    },
    "views": {
      "pixelclaw-panel": [
        {
          "type": "webview",
          "id": "pixelclaw.panelView",
          "name": "PixelClaw"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:webview": "cd webview-ui && npm run build",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run build:webview",
    "build": "npm run compile",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run build:webview",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "import-tileset": "tsx scripts/0-import-tileset.ts",
    "server:build": "node esbuild-server.js",
    "server:start": "node dist/server.js",
    "standalone": "npm run build:webview && npm run server:build && npm run server:start",
    "start": "npm run standalone"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/express": "^5.0.6",
    "@types/node": "22.x",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.107.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "ws": "^8.19.0"
  },
  "overrides": {
    "minimatch": ">=3.1.3"
  }
}
